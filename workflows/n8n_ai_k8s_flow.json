{
  "id": "k8sAIflow000001",
  "name": "AI_K8s_Flow",
  "nodes": [
    {
      "parameters": {
        "public": true,
        "initialMessages": "Hi there! 👋\nMy name is Assad. I am k8s assistant for the kind cluster k8s-ai. How can I assist you today?",
        "options": {
          "title": "K8s AI Assistant",
          "subtitle": "Ask me anything about your Kubernetes cluster"
        }
      },
      "id": "chat-trigger",
      "name": "When chat message received",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [
        180,
        300
      ],
      "webhookId": "k8s-ai-chat"
    },
    {
      "parameters": {
        "agent": "toolsAgent",
        "options": {
          "systemMessage": "You are a Kubernetes cluster monitoring assistant.\nEvery question is about the LIVE cluster. Always call the tool first.\n\nRules:\n1. ALWAYS use kubernetes_knowledge_base tool before answering.\n2. Answer ONLY from tool results. Never invent data.\n3. Output a concise markdown table with columns: Kind | Name | Namespace | Details.\n4. Include ALL matching resources from the tool results — do not omit any.\n5. After the table, add at most one summary sentence.\n6. Never output raw JSON, reasoning, or chain-of-thought.\n7. Never expose resource_uid or secret data values.\n8. If no results: | Status | No indexed Kubernetes resources found |",
          "maxIterations": 2
        }
      },
      "id": "ai-agent",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "model": "qwen3:8b-k8s",
        "options": {
          "temperature": 0,
          "numPredict": 1024,
          "numCtx": 32768
        }
      },
      "id": "ollama-chat-model",
      "name": "Ollama Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        240,
        520
      ],
      "credentials": {
        "ollamaApi": {
          "id": "ollama-local",
          "name": "Ollama Local"
        }
      }
    },
    {
      "parameters": {
        "mode": "retrieve-as-tool",
        "qdrantCollection": {
          "__rl": true,
          "value": "k8s",
          "mode": "id"
        },
        "toolName": "kubernetes_knowledge_base",
        "toolDescription": "Search the Kubernetes cluster knowledge base by semantic similarity. Use this for ANY question about pods, deployments, services, namespaces, secrets, configmaps, replicasets, statefulsets, daemonsets, PVCs, or other Kubernetes resources. Returns matching resources with kind, name, namespace, and spec summary.",
        "topK": 30,
        "includeDocumentMetadata": true,
        "options": {
          "contentPayloadKey": "pageContent",
          "metadataPayloadKey": "metadata"
        }
      },
      "id": "qdrant-vector-store",
      "name": "Qdrant Vector Store",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1,
      "position": [
        560,
        520
      ],
      "credentials": {
        "qdrantApi": {
          "id": "qdrant-local",
          "name": "Qdrant Local"
        }
      }
    },
    {
      "parameters": {
        "model": "nomic-embed-text:latest",
        "options": {}
      },
      "id": "embeddings-ollama",
      "name": "Embeddings Ollama",
      "type": "@n8n/n8n-nodes-langchain.embeddingsOllama",
      "typeVersion": 1,
      "position": [
        560,
        720
      ],
      "credentials": {
        "ollamaApi": {
          "id": "ollama-local",
          "name": "Ollama Local"
        }
      }
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "k8s-ai-global",
        "tableName": "n8n_chat_histories",
        "contextWindowLength": 5
      },
      "id": "postgres-memory",
      "name": "Postgres Chat Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryPostgresChat",
      "typeVersion": 1.3,
      "position": [
        420,
        720
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-local",
          "name": "Postgres Local"
        }
      }
    }
  ],
  "connections": {
    "When chat message received": {
      "main": [
        [
          {
            "node": "AI Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "AI Agent",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Qdrant Vector Store": {
      "ai_tool": [
        [
          {
            "node": "AI Agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "Embeddings Ollama": {
      "ai_embedding": [
        [
          {
            "node": "Qdrant Vector Store",
            "type": "ai_embedding",
            "index": 0
          }
        ]
      ]
    },
    "Postgres Chat Memory": {
      "ai_memory": [
        [
          {
            "node": "AI Agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
