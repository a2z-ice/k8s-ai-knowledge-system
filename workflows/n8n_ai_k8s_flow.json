{
  "id": "k8sAIflow000001",
  "name": "AI_K8s_Flow",
  "nodes": [
    {
      "parameters": {
        "public": true,
        "options": {}
      },
      "id": "chat-trigger",
      "name": "When chat message received",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [
        180,
        300
      ],
      "webhookId": "k8s-ai-chat"
    },
    {
      "parameters": {
        "agent": "toolsAgent",
        "options": {
          "systemMessage": "You are a Kubernetes cluster monitoring assistant. Every question you receive is about the live Kubernetes cluster — even if the word 'kubernetes' is not mentioned.\n\nSTEP 1: ALWAYS call the kubernetes_knowledge_base tool first. Never skip it.\nSTEP 2: Answer ONLY from the retrieved results. Never hallucinate.\nSTEP 3: Respond with a markdown table as your primary output. No reasoning, no explanations, no step-by-step thinking — only the table and at most one short sentence.\n\nOutput rules:\n- PRIMARY format: markdown table (| Column | Column |)\n- If the tool returns no results: output a one-row table: | Status | No indexed Kubernetes resources found |\n- Never include reasoning, chain-of-thought, or verbose explanations\n- Never expose resource_uid values\n- For Secret resources: table may show name and type only — never data values",
          "maxIterations": 2
        }
      },
      "id": "ai-agent",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "model": "qwen3:8b",
        "options": {
          "temperature": 0.1,
          "think": false
        }
      },
      "id": "ollama-chat-model",
      "name": "Ollama Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        240,
        520
      ],
      "credentials": {
        "ollamaApi": {
          "id": "ollama-local",
          "name": "Ollama Local"
        }
      }
    },
    {
      "parameters": {
        "mode": "retrieve-as-tool",
        "qdrantCollection": {
          "__rl": true,
          "value": "k8s",
          "mode": "id"
        },
        "toolName": "kubernetes_knowledge_base",
        "toolDescription": "Search the Kubernetes cluster knowledge base. Use this for any question about pods, deployments, services, namespaces, secrets, configmaps, or other cluster resources.",
        "topK": 10,
        "includeDocumentMetadata": true,
        "options": {
          "contentPayloadKey": "pageContent",
          "metadataPayloadKey": "metadata"
        }
      },
      "id": "qdrant-vector-store",
      "name": "Qdrant Vector Store",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "typeVersion": 1,
      "position": [
        560,
        520
      ],
      "credentials": {
        "qdrantApi": {
          "id": "qdrant-local",
          "name": "Qdrant Local"
        }
      }
    },
    {
      "parameters": {
        "model": "nomic-embed-text:latest",
        "options": {}
      },
      "id": "embeddings-ollama",
      "name": "Embeddings Ollama",
      "type": "@n8n/n8n-nodes-langchain.embeddingsOllama",
      "typeVersion": 1,
      "position": [
        560,
        720
      ],
      "credentials": {
        "ollamaApi": {
          "id": "ollama-local",
          "name": "Ollama Local"
        }
      }
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "k8s-ai-global",
        "tableName": "n8n_chat_histories",
        "contextWindowLength": 5
      },
      "id": "postgres-memory",
      "name": "Postgres Chat Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryPostgresChat",
      "typeVersion": 1.3,
      "position": [
        420,
        720
      ],
      "credentials": {
        "postgres": {
          "id": "postgres-local",
          "name": "Postgres Local"
        }
      }
    }
  ],
  "connections": {
    "When chat message received": {
      "main": [
        [
          {
            "node": "AI Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "AI Agent",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Qdrant Vector Store": {
      "ai_tool": [
        [
          {
            "node": "AI Agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "Embeddings Ollama": {
      "ai_embedding": [
        [
          {
            "node": "Qdrant Vector Store",
            "type": "ai_embedding",
            "index": 0
          }
        ]
      ]
    },
    "Postgres Chat Memory": {
      "ai_memory": [
        [
          {
            "node": "AI Agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
