{
  "id": "k8sRSTflow00001",
  "name": "classic_Reset_K8s_Flow",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        180,
        200
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "k8s-reset",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "reset-webhook",
      "name": "Reset Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        180,
        380
      ],
      "webhookId": "k8s-reset"
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "http://qdrant:6333/collections/k8s",
        "options": {}
      },
      "id": "delete-collection",
      "name": "Delete Qdrant Collection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        460,
        280
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "http://qdrant:6333/collections/k8s",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"vectors\": { \"size\": 768, \"distance\": \"Cosine\" }, \"optimizers_config\": { \"default_segment_number\": 2 }, \"replication_factor\": 1 }",
        "options": {}
      },
      "id": "recreate-collection",
      "name": "Recreate Qdrant Collection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        700,
        280
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://k8s-watcher:8080/resync",
        "options": {}
      },
      "id": "trigger-resync",
      "name": "Trigger Resync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        940,
        280
      ]
    },
    {
      "parameters": {
        "jsCode": "const ts = new Date().toISOString();\nreturn [{ json: { status: 'ok', message: 'Qdrant collection cleared and k8s-watcher resync triggered. Vector database will repopulate within ~30 seconds.', reset_at: ts } }];"
      },
      "id": "format-reset-response",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        280
      ]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Delete Qdrant Collection",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Reset Webhook": {
      "main": [
        [
          {
            "node": "Delete Qdrant Collection",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Delete Qdrant Collection": {
      "main": [
        [
          {
            "node": "Recreate Qdrant Collection",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Recreate Qdrant Collection": {
      "main": [
        [
          {
            "node": "Trigger Resync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Resync": {
      "main": [
        [
          {
            "node": "Format Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}