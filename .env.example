# Copy this file to .env and fill in your values.
# Used by: npm run screenshots
#
# N8N_EMAIL  — the owner email you registered during n8n first-run setup
# N8N_PASS   — the owner password you set during n8n first-run setup
#
# These are your n8n login credentials (set when you first visited localhost:5678).

N8N_EMAIL=your-email@example.com
N8N_PASS=your-password
